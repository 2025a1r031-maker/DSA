#include<stdio.h>
#include<stdlib.h>
#define MAX 100
struct queue{
    int data;
    int priority;
};
struct queue pqueue[MAX];
int front = -1, rear = -1;
int isEmpty(){
    return front == -1;
}
int isFull(){
    return front == MAX -1;
}
void enqueue(int data, int periority){
    if(isFull()){
        printf("Queue Overflow!!!\n");
        return;
    }
    rear ++;
    pqueue[rear].data = data;
    pqueue[rear].priority = periority;
    if(front == -1)
        front = rear;
    printf("Element inserted in periority queue!!!\n");


}
int getHighestPeriority(){
    int max = pqueue[0].priority,index = 0;
    for(int i=1; i<=rear; i++){
        if(pqueue[i].priority > max){
            max = pqueue[i].priority;
            index = i;
        }
    }
    return index;
}

int dequeue(){
    if(isEmpty()){
        printf("Queue Underflow!!!\n");
        return -1;
    }
    else if(front == rear){
        int val = pqueue[front].data;
        front = rear = -1;
        return val;
    }
    else{
    int index = getHighestPeriority();
    int val = pqueue[index].data;
    for(int i = index ; i<rear;i++){
        pqueue[i] = pqueue[i+1]; 
    }
    rear --;
    return val;
    }
}
int peek(){
if(isEmpty()){
        printf("Queue Underflow!!!\n");
        return -1;
    }
    else{
    int index = getHighestPeriority();
    int val = pqueue[index].data;
    return val;
    }
}
void display(){
    if(isEmpty()){
        printf("Queue is empty!!!\n");
        return;
}
for(int i=0; i<=rear;i++){
    printf(" Periority%d --> Value=> %d\n", pqueue[i].priority, pqueue[i].data);
    }
}
int main(){
    int choice, value,periority;
    while(1){
        printf("1. Enqueue\n");
        printf("2. Dequeue\n");
        printf("3. Peek\n");
        printf("4. Display\n");
        printf("5. Exit\n");
        printf("Enter Choice: ");
        scanf("%d", &choice);
        switch(choice){
            case 1:
                printf("Enter value: ");
                scanf("%d", &value);
                printf("Enter periority: ");
                scanf("%d", &periority);
                enqueue(value,periority);
                break;
            case 2:
                value = dequeue();
                if (value != -1)
                printf("%d dequeue from the periority queue!!!\n",value);
                break;
            case 3:
                value = peek();
                if(value != -1){
                 printf("Front element: %d\n", peek());
                }
               
                break;
            case 4:
                display();
                break;
            case 5:
                exit(0);
                break;
            default :
                printf("Invalid");
        }
    }
    return 0;
}
