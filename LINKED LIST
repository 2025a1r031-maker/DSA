#define MAX 100
struct Node{
    int data;
    struct Node* next;
};
struct Node *head = NULL;
struct Node* createNode(int data){
    struct Node* temp=(struct Node*)malloc(sizof(struct Node));
    temp->data=data;
    temp->next =NULL;
    return temp;
}
void insertinbeg(int data){
    struct Node* newNode=createNode(data);
    newNode->next=head;
    head=newNode;
    print("Node inserted in beginning\n");
}
