#include<stdio.h>
#include<stdlib.h>
#define MAX 100
struct Node{
    int data;
    struct Node* next;
};
struct Node *head = NULL;
struct Node* createNode(int data){
    struct Node* temp=(struct Node*)malloc(sizeof(struct Node));
    temp->data=data;
    temp->next =NULL;
    return temp;
}
void insertinbeg(int data){
    struct Node* newNode=createNode(data);
    newNode->next=head;
    head=newNode;
    printf("Node inserted in beginning\n");
}
void insertnodeatend(int data){
    struct Node* newNode =createNode(data);
    if(head == NULL)
    head = newNode;
    else{
        struct Node* temp= head;
        while(temp->next !=NULL){
            temp->next=newNode;
        }
        printf("Node Inserted");
}
}
void insertatanypos(int data,int pos){
    if(head == NULL)
    printf("list is empty");
else if(pos==0)
insertinbeg(data);
else{
    struct Node* temp = head;
    int i=0;
    while(temp!=NULL){
        if(i==pos-1)
        break;
        temp->next;
        i++;
    }
    if(temp == NULL)
    printf("Invalid position!!!\n");
    else{
        struct Node* newnode=createNode(data);
        newnode->next=temp->next;
        temp->next=newnode;
        printf("Node inserted at position %d successfully!!\n",pos);
    }
}
}
void deletefrombeg(){
    if(head==NULL)
    printf("list is empty!");
    else{
        head=head->next;
        printf("node deleted from begining");
    }
}
void deletefromend(){
    if(head==NULL)
    printf("list is empty");
    else{
        struct Node* temp = head;
        while(temp->next->next!=NULL){
            temp =temp->next;
        }
        temp->next=NULL;
        printf("node deleted from end");
    }
}
void deletefromanypos(int pos){
    if(head==NULL)
    printf("list is empty");
    else if(pos==0)
    deletefrombeg();
    else{
        struct Node* temp =head;
       int i=0;
        while(temp!=NULL){
            if(i==pos-1)
            break;
            temp=temp->next;
            i++;
        }
        if(temp==NULL)
        printf("invalid position");
        else{
            if(temp->next !=NULL)
            temp->next=temp->next->next;
            printf("node deleted from position %d successfully!!!\n",pos);
        }
        printf("\n");
    }
}
void displaylist(){
       if(head==NULL){
           printf("list is empty");
           return;
       }
        struct Node* temp =head;
        printf("list : ");
        while(temp!=NULL){
            printf("%d -> ",temp->data);
            temp=temp->next;
}
printf("NULL\n");
}
void search(int data){
     if(head==NULL)
    printf("list is empty");
    else {
        struct Node* temp =head;
        while(temp!=NULL){
            if(temp->data == data){
                printf("element found");
                return;
            }
            temp=temp->next;
        }
        printf("Element not found");
    }
}
    
